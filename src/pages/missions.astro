---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';
import CtaBand from '@components/ui/CtaBand.astro';
import { SITE } from '@data/site';
import { METIERS } from '@data/metiers';
import { organization, breadcrumb, buildGraph } from '@lib/schema';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Missions', url: '/missions' },
];

const supabaseUrl = SITE.supabase.url;
const supabaseKey = SITE.supabase.anonKey;
const notConfigured = supabaseUrl.includes('XXXX') || supabaseKey.includes('XXXX');

const jsonLd = buildGraph(organization(), breadcrumb(breadcrumbs));
---

<BaseLayout
  title="Missions de remplacement disponibles"
  description="Parcourez les missions de remplacement publiées par les établissements de santé : médecin, infirmier, pharmacien, sage-femme, préparateur. Répondez en quelques clics, partout en France."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="section-tight">
    <div class="container-content missions-head" data-reveal>
      <span class="eyebrow">Job board</span>
      <h1 class="h-display">Missions de remplacement disponibles</h1>
      <p class="lede missions-lede">
        Les besoins publiés par les établissements de santé, en temps réel. Filtrez par
        métier et par ville, puis répondez à la mission qui vous intéresse.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-content">
      <div class="filters" data-reveal>
        <div class="field filter-field">
          <label class="field-label" for="filter-metier">Métier</label>
          <select id="filter-metier" class="select">
            <option value="">Tous les métiers</option>
            {METIERS.map((m) => <option value={m.nom}>{m.nom}</option>)}
          </select>
        </div>
        <div class="field filter-field">
          <label class="field-label" for="filter-ville">Ville</label>
          <input id="filter-ville" class="input" type="text" placeholder="Ex. Lyon" />
        </div>
        <p class="filter-count text-subtle" id="missions-count" aria-live="polite"></p>
      </div>

      <div id="missions-list" class="missions-list" aria-live="polite">
        {
          notConfigured ? (
            <div class="missions-state card">
              <h2 class="state-titre">Bientôt en ligne</h2>
              <p class="text-muted">
                Le stockage des missions n’est pas encore configuré. Renseignez votre projet
                Supabase dans <code>src/data/site.ts</code> et exécutez{' '}
                <code>supabase-schema.sql</code> pour activer le job board.
              </p>
            </div>
          ) : (
            <div class="missions-state card" id="missions-loading">
              <p class="text-muted">Chargement des missions…</p>
            </div>
          )
        }
      </div>

      <div class="missions-cta card" data-reveal>
        <div>
          <h2 class="cta-titre">Vous êtes un établissement ?</h2>
          <p class="text-muted">Publiez votre besoin et il apparaîtra ici après validation.</p>
        </div>
        <a href="/publier-un-besoin" class="btn-primary btn-lg">Publier un besoin</a>
      </div>
    </div>
  </section>

  <CtaBand titre="Pas encore inscrit comme remplaçant ?" texte="Créez votre profil pour être prévenu dès qu’une mission correspond à vos critères." />
</BaseLayout>

<style>
  .missions-head {
    max-width: 44rem;
  }
  .missions-lede {
    margin-top: 1rem;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .filter-field {
    min-width: 12rem;
    flex: 1;
  }
  .filter-count {
    font-size: var(--text-sm);
    margin-left: auto;
    padding-bottom: 0.75rem;
  }
  .missions-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .missions-list {
      grid-template-columns: 1fr 1fr;
    }
  }
  .missions-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 2.5rem;
  }
  .state-titre {
    font-size: 1.375rem;
    margin-bottom: 0.5rem;
  }
  .missions-state code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-tint);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  /* Cartes mission (rendues en JS) */
  :global(.mission-card) {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  :global(.mission-top) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  :global(.mission-metier) {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--color-fg);
  }
  :global(.mission-badge) {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 0.25rem 0.6875rem;
    border-radius: var(--radius-full);
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }
  :global(.mission-badge.urgent) {
    background: #fee2e2;
    color: #b91c1c;
  }
  :global(.mission-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }
  :global(.mission-meta span) {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  :global(.mission-details) {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: 1.55;
  }
  :global(.mission-foot) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }
  :global(.mission-date) {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }

  .missions-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1.75rem 2rem;
    margin-top: 2rem;
  }
  .cta-titre {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }
</style>

<script is:inline define:vars={{ supabaseUrl, supabaseKey, notConfigured }}>
  function initMissions() {
    const list = document.getElementById('missions-list');
    if (!list || notConfigured || list.dataset.bound === 'true') return;
    list.dataset.bound = 'true';

    const countEl = document.getElementById('missions-count');
    const filterMetier = document.getElementById('filter-metier');
    const filterVille = document.getElementById('filter-ville');
    let missions = [];

    const esc = (s) =>
      String(s ?? '').replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      })[c]);

    const fmtDate = (d) =>
      d ? new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date(d)) : null;

    function periode(m) {
      const a = fmtDate(m.date_debut);
      const b = fmtDate(m.date_fin);
      if (a && b) return `${a} → ${b}`;
      if (a) return `À partir du ${a}`;
      return 'Dates à convenir';
    }

    function cardHtml(m) {
      const urgent = (m.type_mission || '').toLowerCase() === 'urgent';
      const params = new URLSearchParams();
      if (m.metier) params.set('metier', m.metier);
      params.set('mission', m.id);
      const lieu = [m.ville, m.type_etablissement].filter(Boolean).map(esc).join(' · ');
      return `
        <article class="mission-card">
          <div class="mission-top">
            <span class="mission-metier">${esc(m.metier || 'Remplacement')}</span>
            ${m.type_mission ? `<span class="mission-badge ${urgent ? 'urgent' : ''}">${esc(m.type_mission)}</span>` : ''}
          </div>
          <div class="mission-meta">
            ${lieu ? `<span>📍 ${lieu}</span>` : ''}
            <span>🗓️ ${esc(periode(m))}</span>
            ${m.remuneration ? `<span>💶 ${esc(m.remuneration)}</span>` : ''}
          </div>
          ${m.details ? `<p class="mission-details">${esc(m.details)}</p>` : ''}
          <div class="mission-foot">
            <span class="mission-date">Publié le ${esc(fmtDate(m.created_at) || '')}</span>
            <a class="btn-primary" href="/inscription-remplacant?${params.toString()}">Répondre</a>
          </div>
        </article>`;
    }

    function render() {
      const mt = filterMetier.value;
      const vl = filterVille.value.trim().toLowerCase();
      const filtered = missions.filter((m) => {
        if (mt && m.metier !== mt) return false;
        if (vl && !(m.ville || '').toLowerCase().includes(vl)) return false;
        return true;
      });
      countEl.textContent = `${filtered.length} mission${filtered.length > 1 ? 's' : ''}`;
      if (filtered.length === 0) {
        list.innerHTML =
          '<div class="missions-state card"><h2 class="state-titre">Aucune mission pour ces critères</h2><p class="text-muted">Élargissez votre recherche, ou inscrivez-vous pour être prévenu des nouvelles missions.</p></div>';
        return;
      }
      list.innerHTML = filtered.map(cardHtml).join('');
    }

    filterMetier.addEventListener('change', render);
    filterVille.addEventListener('input', render);

    fetch(`${supabaseUrl}/rest/v1/missions_publiques?select=*&order=created_at.desc`, {
      headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` },
    })
      .then((r) => (r.ok ? r.json() : Promise.reject(r)))
      .then((data) => {
        missions = Array.isArray(data) ? data : [];
        render();
      })
      .catch(() => {
        list.innerHTML =
          '<div class="missions-state card"><p class="text-muted">Impossible de charger les missions pour le moment. Réessayez plus tard.</p></div>';
      });
  }

  initMissions();
  document.addEventListener('astro:page-load', initMissions);
</script>
