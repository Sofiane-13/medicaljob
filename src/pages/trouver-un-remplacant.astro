---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';
import CtaBand from '@components/ui/CtaBand.astro';
import { SITE } from '@data/site';
import { METIERS } from '@data/metiers';
import { organization, breadcrumb, buildGraph } from '@lib/schema';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Trouver un remplaçant', url: '/trouver-un-remplacant' },
];

const supabaseUrl = SITE.supabase.url;
const supabaseKey = SITE.supabase.anonKey;
const notConfigured = supabaseUrl.includes('XXXX') || supabaseKey.includes('XXXX');

const jsonLd = buildGraph(organization(), breadcrumb(breadcrumbs));
---

<BaseLayout
  title="Trouver un remplaçant en santé — annuaire des disponibilités"
  description="Parcourez les profils de professionnels de santé remplaçants disponibles : médecins, infirmiers, pharmaciens, sages-femmes, préparateurs. Filtrez par métier et par zone, puis demandez une mise en relation."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="section-tight">
    <div class="container-content dir-head" data-reveal>
      <span class="eyebrow">Pour les établissements</span>
      <h1 class="h-display">Trouvez un remplaçant disponible</h1>
      <p class="lede dir-lede">
        Parcourez les profils des professionnels de santé inscrits et disponibles.
        Filtrez par métier et par zone, puis demandez une mise en relation — leurs
        coordonnées restent protégées jusqu’à votre prise de contact.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-content">
      <div class="filters" data-reveal>
        <div class="field filter-field">
          <label class="field-label" for="filter-metier">Métier</label>
          <select id="filter-metier" class="select">
            <option value="">Tous les métiers</option>
            {METIERS.map((m) => <option value={m.nom}>{m.nom}</option>)}
          </select>
        </div>
        <div class="field filter-field">
          <label class="field-label" for="filter-zone">Zone / ville</label>
          <input id="filter-zone" class="input" type="text" placeholder="Ex. Lyon" />
        </div>
        <div class="field filter-field">
          <label class="field-label" for="filter-dispo">Disponibilité</label>
          <select id="filter-dispo" class="select">
            <option value="">Toutes</option>
            <option value="Immédiate">Immédiate</option>
            <option value="Sous 1 mois">Sous 1 mois</option>
            <option value="Ponctuelle">Ponctuelle</option>
            <option value="Week-ends">Week-ends</option>
          </select>
        </div>
        <p class="filter-count text-subtle" id="dir-count" aria-live="polite"></p>
      </div>

      <div id="dir-list" class="dir-grid" aria-live="polite">
        {
          notConfigured ? (
            <div class="dir-state card">
              <h2 class="state-titre">Bientôt en ligne</h2>
              <p class="text-muted">
                Le stockage n’est pas encore configuré. Renseignez Supabase dans
                <code>src/data/site.ts</code> et exécutez <code>supabase-migration-recherche.sql</code>.
              </p>
            </div>
          ) : (
            <div class="dir-state card">
              <p class="text-muted">Chargement des profils…</p>
            </div>
          )
        }
      </div>

      <div id="dir-sentinel" class="list-sentinel" hidden aria-hidden="true">Chargement…</div>

      <div class="dir-cta card" data-reveal>
        <div>
          <h2 class="cta-titre">Vous êtes un professionnel de santé ?</h2>
          <p class="text-muted">Créez votre profil pour apparaître dans cet annuaire.</p>
        </div>
        <a href="/inscription-remplacant" class="btn-primary btn-lg">Créer mon profil</a>
      </div>
    </div>
  </section>

  <CtaBand
    titre="Besoin précis et urgent ?"
    texte="Publiez directement votre besoin : il sera diffusé à tous les remplaçants correspondants."
  />
</BaseLayout>

<style>
  .dir-head {
    max-width: 46rem;
  }
  .dir-lede {
    margin-top: 1rem;
  }
  .filters {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .filter-field {
    min-width: 11rem;
    flex: 1;
  }
  .filter-count {
    font-size: var(--text-sm);
    margin-left: auto;
    padding-bottom: 0.75rem;
  }
  .dir-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .dir-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1100px) {
    .dir-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }
  .dir-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 2.5rem;
  }
  .state-titre {
    font-size: 1.375rem;
    margin-bottom: 0.5rem;
  }
  .dir-state code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--color-bg-tint);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }

  /* Cartes profil (rendues en JS) */
  :global(.profil-card) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  :global(.profil-top) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  :global(.profil-metier) {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-fg);
  }
  :global(.profil-dispo) {
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
    background: var(--color-teal-soft);
    color: var(--color-teal);
    white-space: nowrap;
  }
  :global(.profil-meta) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }
  :global(.profil-meta span) {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  :global(.profil-foot) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }
  :global(.profil-ref) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }

  .list-sentinel {
    text-align: center;
    padding: 1.25rem;
    font-size: var(--text-sm);
    color: var(--color-fg-subtle);
  }
  .list-sentinel[hidden] {
    display: none;
  }

  .dir-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1.75rem 2rem;
    margin-top: 2rem;
  }
  .cta-titre {
    font-size: 1.25rem;
    margin-bottom: 0.25rem;
  }
</style>

<script is:inline define:vars={{ supabaseUrl, supabaseKey, notConfigured }}>
  function initDirectory() {
    const list = document.getElementById('dir-list');
    if (!list || notConfigured || list.dataset.bound === 'true') return;
    list.dataset.bound = 'true';

    const countEl = document.getElementById('dir-count');
    const fMetier = document.getElementById('filter-metier');
    const fZone = document.getElementById('filter-zone');
    const fDispo = document.getElementById('filter-dispo');
    let profils = [];

    const esc = (s) =>
      String(s ?? '').replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
      })[c]);

    const fmtDate = (d) =>
      d ? new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date(d)) : '';

    function cardHtml(p) {
      const ref = String(p.id || '').slice(0, 8);
      const params = new URLSearchParams();
      if (p.metier) params.set('metier', p.metier);
      params.set('profil', ref);
      return `
        <article class="profil-card">
          <div class="profil-top">
            <span class="profil-metier">${esc(p.metier || 'Professionnel de santé')}</span>
            ${p.disponibilite ? `<span class="profil-dispo">${esc(p.disponibilite)}</span>` : ''}
          </div>
          <div class="profil-meta">
            ${p.zones ? `<span>📍 ${esc(p.zones)}</span>` : ''}
            ${p.type_mission ? `<span>💼 ${esc(p.type_mission)}</span>` : ''}
          </div>
          <div class="profil-foot">
            <span class="profil-ref">Profil #${esc(ref)}</span>
            <a class="btn-primary" href="/publier-un-besoin?${params.toString()}">Contacter</a>
          </div>
        </article>`;
    }

    const sentinel = document.getElementById('dir-sentinel');
    const CHUNK = 12;
    let filtered = [];
    let rendered = 0;

    function renderMore() {
      const next = filtered.slice(rendered, rendered + CHUNK);
      if (next.length) {
        list.insertAdjacentHTML('beforeend', next.map(cardHtml).join(''));
        rendered += next.length;
      }
      if (sentinel) sentinel.hidden = rendered >= filtered.length;
    }

    function applyFilters() {
      const mt = fMetier.value;
      const zn = fZone.value.trim().toLowerCase();
      const dp = fDispo.value;
      filtered = profils.filter((p) => {
        if (mt && p.metier !== mt) return false;
        if (dp && p.disponibilite !== dp) return false;
        if (zn && !(p.zones || '').toLowerCase().includes(zn)) return false;
        return true;
      });
      countEl.textContent = `${filtered.length} profil${filtered.length > 1 ? 's' : ''}`;
      list.innerHTML = '';
      rendered = 0;
      if (filtered.length === 0) {
        if (sentinel) sentinel.hidden = true;
        list.innerHTML =
          '<div class="dir-state card"><h2 class="state-titre">Aucun profil pour ces critères</h2><p class="text-muted">Élargissez votre recherche, ou publiez un besoin pour toucher tous les remplaçants concernés.</p></div>';
        return;
      }
      renderMore();
    }

    if (sentinel && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) renderMore(); }),
        { rootMargin: '400px 0px' }
      );
      io.observe(sentinel);
    }

    fMetier.addEventListener('change', applyFilters);
    fDispo.addEventListener('change', applyFilters);
    fZone.addEventListener('input', applyFilters);

    fetch(`${supabaseUrl}/rest/v1/remplacants_publics?select=*&order=created_at.desc`, {
      headers: { apikey: supabaseKey, Authorization: `Bearer ${supabaseKey}` },
    })
      .then((r) => (r.ok ? r.json() : Promise.reject(r)))
      .then((data) => {
        profils = Array.isArray(data) ? data : [];
        applyFilters();
      })
      .catch(() => {
        if (sentinel) sentinel.hidden = true;
        list.innerHTML =
          '<div class="dir-state card"><p class="text-muted">Impossible de charger les profils pour le moment. Réessayez plus tard.</p></div>';
      });
  }

  initDirectory();
  document.addEventListener('astro:page-load', initDirectory);
</script>
