---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';
import CtaBand from '@components/ui/CtaBand.astro';
import { organization, breadcrumb, buildGraph } from '@lib/schema';
import { SITE } from '@data/site';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: post.data.title, url: `/blog/${post.id}` },
];

const url = `${SITE.url}/blog/${post.id}`;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${url}#article`,
  headline: post.data.title,
  description: post.data.description,
  url,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
  inLanguage: 'fr-FR',
  author: { '@type': 'Organization', name: post.data.author, url: SITE.url },
  publisher: { '@id': `${SITE.url}#organization` },
  mainEntityOfPage: url,
  ...(post.data.targetKeyword ? { keywords: post.data.targetKeyword } : {}),
};

const jsonLd = buildGraph(organization(), breadcrumb(breadcrumbs), articleJsonLd);

const formatDate = (d: Date) =>
  new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

const toc = headings.filter((h) => h.depth === 2);

const allPosts = await getCollection('blog');
const related = allPosts.filter((p) => p.id !== post.id).slice(0, 2);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbs} />

  <article class="article">
    <header class="article-head" data-reveal>
      <div class="article-meta">
        <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
        {post.data.readingTime && <span>· {post.data.readingTime}</span>}
        <span>· {post.data.author}</span>
      </div>
      <h1 class="article-title">{post.data.title}</h1>
      <p class="article-lede">{post.data.description}</p>
    </header>

    {
      toc.length > 0 && (
        <nav class="article-toc" aria-label="Sommaire" data-reveal>
          <span class="toc-label">Sommaire</span>
          <ol>
            {toc.map((h) => (
              <li>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }

    <div class="article-prose">
      <Content />
    </div>
  </article>

  {
    related.length > 0 && (
      <section class="section bg-soft">
        <div class="container-content related-wrap">
          <h2 class="h-section related-titre">À lire aussi</h2>
          <ul class="related-list grid-2">
            {related.map((p) => (
              <li>
                <a href={`/blog/${p.id}`} class="related-link card card-hover">
                  <span class="related-title">{p.data.title}</span>
                  <span class="related-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <CtaBand />
</BaseLayout>

<style is:global>
  .article {
    max-width: 44rem;
    margin-inline: auto;
    padding-inline: 1.25rem;
    padding-block: clamp(2rem, 4vw, 3.5rem) clamp(3rem, 6vw, 5rem);
  }
  .article-head {
    padding-bottom: 2rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-fg-subtle);
    margin-bottom: 1.25rem;
  }
  .article-title {
    font-size: clamp(1.875rem, 4.5vw, 3rem);
    line-height: 1.1;
  }
  .article-lede {
    margin-top: 1.25rem;
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    line-height: 1.55;
  }
  .article-toc {
    padding: 1.5rem;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-bottom: 2.5rem;
  }
  .toc-label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-subtle);
    margin-bottom: 0.75rem;
  }
  .article-toc ol {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-left: 1.25rem;
  }
  .article-toc a {
    color: var(--color-fg);
  }
  .article-toc a:hover {
    color: var(--color-accent);
  }

  .article-prose {
    color: var(--color-fg-muted);
    line-height: 1.75;
    font-size: 1.0625rem;
  }
  .article-prose h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-fg);
    margin: 2.75rem 0 1rem;
    scroll-margin-top: 5rem;
  }
  .article-prose h3 {
    font-size: 1.25rem;
    color: var(--color-fg);
    margin: 2rem 0 0.75rem;
  }
  .article-prose p {
    margin-bottom: 1.25rem;
  }
  .article-prose ul,
  .article-prose ol {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }
  .article-prose ul {
    list-style: disc;
  }
  .article-prose ol {
    list-style: decimal;
  }
  .article-prose li {
    margin-bottom: 0.5rem;
  }
  .article-prose strong {
    color: var(--color-fg);
  }
  .article-prose a {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .article-prose blockquote {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-soft);
    border-left: 3px solid var(--color-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    color: var(--color-fg);
  }
  .article-prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
  }
  .article-prose th,
  .article-prose td {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .article-prose th {
    background: var(--color-bg-soft);
    color: var(--color-fg);
  }
  .article-prose .tldr {
    padding: 1.5rem;
    background: var(--color-accent-soft);
    border: 1px solid #c5dbfb;
    border-radius: var(--radius-md);
    margin: 0 0 2.5rem;
  }
  .article-prose .tldr-label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }
  .article-prose .tldr p {
    margin-bottom: 0;
    color: var(--color-fg);
  }

  .related-wrap {
    max-width: 52rem;
  }
  .related-titre {
    margin-bottom: 1.5rem;
  }
  .related-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    font-weight: 600;
  }
  .related-arrow {
    color: var(--color-accent);
  }
</style>
