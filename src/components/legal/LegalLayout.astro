---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';

export type Props = {
  title: string;
  description: string;
  maj?: string;
};

const { title, description, maj } = Astro.props;
const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: title, url: Astro.url.pathname },
];
---

<BaseLayout title={title} description={description} noindex={true}>
  <Breadcrumbs items={breadcrumbs} />
  <article class="legal">
    <div class="container-content legal-inner">
      <h1 class="h-display legal-title">{title}</h1>
      {maj && <p class="legal-maj text-subtle">Dernière mise à jour : {maj}</p>}
      <div class="legal-prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .legal {
    padding-block: clamp(2.5rem, 5vw, 4rem) clamp(4rem, 8vw, 6rem);
  }
  .legal-inner {
    max-width: 46rem;
  }
  .legal-title {
    font-size: clamp(1.875rem, 4vw, 2.75rem);
  }
  .legal-maj {
    margin-top: 0.5rem;
    font-size: var(--text-sm);
  }
  .legal-prose {
    margin-top: 2.5rem;
    color: var(--color-fg-muted);
    line-height: 1.7;
  }
  .legal-prose h2 {
    font-size: 1.375rem;
    color: var(--color-fg);
    margin: 2.5rem 0 0.75rem;
  }
  .legal-prose p {
    margin-bottom: 1rem;
  }
  .legal-prose ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .legal-prose li {
    margin-bottom: 0.5rem;
  }
  .legal-prose a {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .legal-prose strong {
    color: var(--color-fg);
  }
</style>
