---
import { NAV, SITE } from '@data/site';
---

<header class="site-header">
  <div class="container-content header-inner">
    <a href="/" class="brand" aria-label={SITE.name}>
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M12 5v14M5 12h14" />
        </svg>
      </span>
      <span class="brand-word">Medical<span class="brand-accent">Job</span></span>
    </a>

    <nav class="primary-nav" aria-label="Navigation principale">
      {NAV.primary.map((item) => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
    </nav>

    <div class="header-cta">
      <a href="/inscription-remplacant" class="nav-link header-login">Je suis remplaçant</a>
      <a href="/publier-un-besoin" class="btn-primary header-pub">Publier un besoin</a>
      <button
        id="menu-toggle"
        class="menu-toggle"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
      </button>
    </div>
  </div>
</header>

<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <nav aria-label="Navigation mobile" class="mobile-nav">
    {NAV.primary.map((item) => (
      <a href={item.href} class="mobile-nav-link" data-close-menu>{item.label}</a>
    ))}
    <div class="mobile-actions">
      <a href="/inscription-remplacant" class="btn-secondary btn-block" data-close-menu>Je cherche un remplacement</a>
      <a href="/publier-un-besoin" class="btn-primary btn-block" data-close-menu>Publier un besoin</a>
    </div>
  </nav>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.75rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 7px;
    background: var(--color-accent);
    color: #fff;
  }
  .brand-mark svg {
    width: 1rem;
    height: 1rem;
  }
  .brand-accent {
    color: var(--color-accent);
  }

  .primary-nav {
    display: none;
    align-items: center;
    gap: 1.75rem;
  }
  @media (min-width: 1024px) {
    .primary-nav {
      display: flex;
    }
  }
  .nav-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-fg-muted);
    transition: color 0.2s ease;
  }
  .nav-link:hover {
    color: var(--color-accent);
  }

  .header-cta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .header-login {
    display: none;
  }
  .header-pub {
    display: none;
  }
  @media (min-width: 1024px) {
    .header-login {
      display: inline-block;
    }
    .header-pub {
      display: inline-flex;
    }
  }

  .menu-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 44px;
    height: 44px;
    align-items: center;
    background: transparent;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-full);
    cursor: pointer;
  }
  @media (min-width: 1024px) {
    .menu-toggle {
      display: none;
    }
  }
  .menu-bar {
    width: 16px;
    height: 2px;
    background: var(--color-fg);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.2s ease;
  }
  :global(html.menu-open) .menu-toggle .menu-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  :global(html.menu-open) .menu-toggle .menu-bar:nth-child(2) {
    opacity: 0;
  }
  :global(html.menu-open) .menu-toggle .menu-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    top: 61px;
    z-index: 45;
    background: var(--color-bg);
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease, transform 0.25s ease;
    overflow-y: auto;
  }
  :global(html.menu-open) .mobile-menu {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1.5rem 2.5rem;
    max-width: 32rem;
    margin-inline: auto;
  }
  .mobile-nav-link {
    padding: 1rem 0;
    font-size: 1.25rem;
    font-weight: 600;
    border-bottom: 1px solid var(--color-border);
  }
  .mobile-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 2rem;
  }
  :global(html.menu-open) {
    overflow: hidden;
  }
</style>

<script>
  function initMenu() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;
    const html = document.documentElement;

    const close = () => {
      html.classList.remove('menu-open');
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    };
    const toggleMenu = () => {
      const open = html.classList.toggle('menu-open');
      toggle.setAttribute('aria-expanded', String(open));
      menu.setAttribute('aria-hidden', String(!open));
    };

    toggle.addEventListener('click', toggleMenu);
    menu.querySelectorAll('[data-close-menu]').forEach((el) =>
      el.addEventListener('click', close)
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }
  initMenu();
  document.addEventListener('astro:page-load', initMenu);
</script>
