---
import { breadcrumb as breadcrumbSchema } from '@lib/schema';
import JsonLd from './JsonLd.astro';

export type Crumb = { name: string; url: string };
export type Props = {
  items: Crumb[];
};

const { items } = Astro.props;
const schema = breadcrumbSchema(items);
---

<nav aria-label="Fil d'Ariane" class="breadcrumbs">
  <div class="container-content">
    <ol>
      {
        items.map((item, i) => (
          <li>
            {i > 0 && <span class="sep" aria-hidden="true">/</span>}
            {i === items.length - 1 ? (
              <span aria-current="page">{item.name}</span>
            ) : (
              <a href={item.url}>{item.name}</a>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</nav>

<JsonLd data={schema} />

<style>
  .breadcrumbs {
    padding-block: 1rem;
    font-size: var(--text-sm);
    color: var(--color-fg-subtle);
    border-bottom: 1px solid var(--color-border);
  }
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .breadcrumbs li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .breadcrumbs a:hover {
    color: var(--color-accent);
  }
  .breadcrumbs [aria-current='page'] {
    color: var(--color-fg);
  }
  .sep {
    color: var(--color-border-strong);
  }
</style>
