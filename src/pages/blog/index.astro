---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';
import CtaBand from '@components/ui/CtaBand.astro';
import { getCollection } from 'astro:content';
import { organization, breadcrumb, buildGraph } from '@lib/schema';
import { SITE } from '@data/site';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Blog', url: '/blog' },
];

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const clusterLabels: Record<string, string> = {
  statut: 'Statut & cadre',
  remuneration: 'Rémunération',
  pratique: 'Pratique',
  sectoriel: 'Sectoriel',
  general: 'Général',
};

const formatDate = (d: Date) =>
  new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);

const jsonLd = buildGraph(organization(), breadcrumb(breadcrumbs), {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${SITE.url}/blog#blog`,
  name: 'Blog MedicalJob',
  description:
    'Guides sur le remplacement en santé : statut, rémunération, démarches et bonnes pratiques pour médecins, infirmiers, pharmaciens et sages-femmes.',
  url: `${SITE.url}/blog`,
  publisher: { '@id': `${SITE.url}#organization` },
  blogPost: posts.slice(0, 10).map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    url: `${SITE.url}/blog/${p.id}`,
    datePublished: p.data.publishedAt.toISOString(),
  })),
});
---

<BaseLayout
  title="Blog — Guides sur le remplacement en santé"
  description="Statut du remplaçant, rémunération, démarches ordinales et bonnes pratiques : tous nos guides pour les remplacements en hôpital, EHPAD, cabinet et officine."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="section">
    <div class="container-content blog-head" data-reveal>
      <span class="eyebrow">Blog · {posts.length} articles</span>
      <h1 class="h-display">Guides sur le remplacement en santé</h1>
      <p class="lede blog-lede">
        Statut, rémunération, contrats et démarches : tout ce qu’il faut savoir pour
        réussir vos remplacements, côté établissement comme côté professionnel.
      </p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-content">
      {
        posts.length === 0 ? (
          <p class="text-subtle">Les premiers articles arrivent bientôt.</p>
        ) : (
          <ul class="posts-grid grid-3">
            {posts.map((post) => (
              <li class="post-card card card-hover" data-reveal>
                <a href={`/blog/${post.id}`} class="post-link">
                  <span class="post-cluster">{clusterLabels[post.data.cluster]}</span>
                  <h2 class="post-title">{post.data.title}</h2>
                  <p class="post-desc text-muted">{post.data.description}</p>
                  <span class="post-meta text-subtle">
                    {formatDate(post.data.publishedAt)}
                    {post.data.readingTime && <> · {post.data.readingTime}</>}
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  .blog-head {
    max-width: 44rem;
  }
  .blog-lede {
    margin-top: 1rem;
  }
  .posts-grid {
    gap: 1.5rem;
  }
  .post-card {
    padding: 0;
    overflow: hidden;
  }
  .post-link {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.75rem;
    height: 100%;
  }
  .post-cluster {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    font-weight: 600;
  }
  .post-title {
    font-size: 1.25rem;
    line-height: 1.25;
  }
  .post-desc {
    font-size: var(--text-sm);
    flex: 1;
  }
  .post-meta {
    font-size: var(--text-xs);
    margin-top: 0.5rem;
  }
</style>
