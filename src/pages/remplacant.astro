---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/seo/Breadcrumbs.astro';

const breadcrumbs = [
  { name: 'Accueil', url: '/' },
  { name: 'Trouver un remplaçant', url: '/trouver-un-remplacant' },
  { name: 'Profil', url: '/remplacant' },
];
---

<BaseLayout
  title="Profil d’un remplaçant"
  description="Détail d’un profil de professionnel de santé remplaçant disponible sur MedicalJob."
  noindex={true}
>
  <Breadcrumbs items={breadcrumbs} />

  <section class="section">
    <div class="container-content profil-wrap">
      <a href="/trouver-un-remplacant" class="back-link">← Retour à l’annuaire</a>
      <div id="profil-detail" aria-live="polite">
        <div class="card profil-state"><p class="text-muted">Chargement du profil…</p></div>
      </div>
      <div id="profil-action"></div>
    </div>
  </section>
</BaseLayout>

<style>
  .profil-wrap { max-width: 44rem; }
  .back-link { display: inline-block; margin-bottom: 1.5rem; font-size: var(--text-sm); font-weight: 600; color: var(--color-accent); }
  .back-link:hover { text-decoration: underline; }
  .profil-state { padding: 2.5rem; text-align: center; }

  :global(.pd-card) { padding: 2rem; }
  :global(.pd-head) { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; }
  :global(.pd-metier) { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; }
  :global(.pd-dispo) { font-size: var(--text-sm); font-weight: 600; padding: 0.3rem 0.75rem; border-radius: var(--radius-full); background: var(--color-teal-soft); color: var(--color-teal); }
  :global(.pd-grid) { display: grid; grid-template-columns: 1fr; gap: 1rem; margin-bottom: 0.5rem; }
  @media (min-width: 560px) { :global(.pd-grid) { grid-template-columns: 1fr 1fr; } }
  :global(.pd-item) { display: flex; flex-direction: column; gap: 0.25rem; padding: 1rem 1.25rem; background: var(--color-bg-soft); border: 1px solid var(--color-border); border-radius: var(--radius-md); }
  :global(.pd-label) { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-fg-subtle); font-weight: 600; }
  :global(.pd-value) { font-weight: 600; color: var(--color-fg); }

  .action-card { margin-top: 1.5rem; padding: 1.75rem 2rem; }
  .action-card h2 { font-size: 1.25rem; margin-bottom: 0.75rem; }
  .action-msg { color: var(--color-fg-muted); margin-bottom: 1rem; }
  .action-field, .action-select { width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--color-border-strong); border-radius: var(--radius-md); font: inherit; margin-bottom: 1rem; background: #fff; }
  .action-field { min-height: 5rem; resize: vertical; }
  .action-note { font-size: var(--text-sm); padding: 0.875rem 1rem; border-radius: var(--radius-md); }
  .action-note.ok { background: var(--color-teal-soft); color: #065f46; }
  .action-note.info { background: var(--color-accent-soft); color: var(--color-accent); }
</style>

<script>
  import { supabase, supabaseConfigured } from '@lib/supabaseClient';

  const esc = (s: unknown) =>
    String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string)
    );
  const fmtDate = (d: string | null) =>
    d ? new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(d)) : '';

  async function initProfil() {
    const box = document.getElementById('profil-detail');
    const actionBox = document.getElementById('profil-action');
    if (!box || !actionBox || box.dataset.bound === 'true') return;
    box.dataset.bound = 'true';

    const notFound = () => {
      box.innerHTML =
        '<div class="card profil-state"><h2 class="state-titre">Profil introuvable</h2><p class="text-muted">Ce profil n’est plus disponible. <a href="/trouver-un-remplacant">Voir les autres remplaçants</a>.</p></div>';
    };

    if (!supabaseConfigured) {
      box.innerHTML = '<div class="card profil-state"><p class="text-muted">Stockage non configuré.</p></div>';
      return;
    }

    const id = new URLSearchParams(window.location.search).get('id');
    if (!id) {
      notFound();
      return;
    }

    const { data: p } = await supabase.from('remplacants_publics').select('*').eq('id', id).maybeSingle();
    if (!p) {
      notFound();
      return;
    }

    const item = (label: string, value: unknown) =>
      value ? `<div class="pd-item"><span class="pd-label">${esc(label)}</span><span class="pd-value">${esc(value)}</span></div>` : '';

    box.innerHTML = `
      <article class="card pd-card">
        <div class="pd-head">
          <span class="pd-metier">${esc(p.metier || 'Professionnel de santé')}</span>
          ${p.disponibilite ? `<span class="pd-dispo">${esc(p.disponibilite)}</span>` : ''}
        </div>
        <div class="pd-grid">
          ${item('Zones géographiques', p.zones)}
          ${item('Disponibilité', p.disponibilite)}
          ${item('Type de mission', p.type_mission)}
          ${item('Profil ajouté le', fmtDate(p.created_at))}
        </div>
      </article>`;

    await renderAction(id, p, actionBox);
  }

  async function renderAction(profilId: string, p: any, actionBox: HTMLElement) {
    const {
      data: { session },
    } = await supabase.auth.getSession();

    if (!session) {
      actionBox.innerHTML = `
        <div class="card action-card">
          <h2>Ce profil correspond à votre besoin ?</h2>
          <p class="action-msg">Connectez-vous comme établissement pour lui proposer une de vos missions.</p>
          <a class="btn-primary btn-lg" href="/connexion?redirect=${encodeURIComponent('/remplacant?id=' + profilId)}">Se connecter pour proposer</a>
        </div>`;
      return;
    }

    const uid = session.user.id;

    // Est-ce mon propre profil ?
    const { data: mine } = await supabase.from('remplacants').select('id').eq('id', profilId).eq('owner_id', uid).maybeSingle();
    if (mine) {
      actionBox.innerHTML = `
        <div class="card action-card">
          <h2>C’est votre profil</h2>
          <p class="action-msg">Retrouvez les propositions reçues dans votre espace.</p>
          <a class="btn-primary" href="/mon-espace">Gérer dans Mon espace</a>
        </div>`;
      return;
    }

    // Mes missions (établissement)
    const { data: missions } = await supabase
      .from('besoins')
      .select('id, metier, ville, statut')
      .eq('owner_id', uid)
      .order('created_at', { ascending: false });

    if (!missions || missions.length === 0) {
      actionBox.innerHTML = `
        <div class="card action-card">
          <h2>Proposer une mission</h2>
          <p class="action-msg">Publiez d’abord une mission pour pouvoir la proposer à ce profil.</p>
          <a class="btn-primary btn-lg" href="/publier-un-besoin">Publier un besoin</a>
        </div>`;
      return;
    }

    const options = missions
      .map((m: any) => `<option value="${esc(m.id)}">${esc(m.metier || 'Mission')}${m.ville ? ' — ' + esc(m.ville) : ''}</option>`)
      .join('');

    actionBox.innerHTML = `
      <div class="card action-card">
        <h2>Proposer une mission à ce profil</h2>
        <p class="action-msg">Choisissez la mission concernée et ajoutez un message. Vos coordonnées ne seront partagées qu’après acceptation.</p>
        <select id="proposer-mission" class="action-select">${options}</select>
        <textarea id="proposer-msg" class="action-field" placeholder="Bonjour, votre profil correspond à notre besoin…"></textarea>
        <button id="proposer-btn" class="btn-primary btn-lg">Envoyer la proposition</button>
      </div>`;

    const btn = document.getElementById('proposer-btn') as HTMLButtonElement;
    btn.addEventListener('click', async () => {
      btn.disabled = true;
      btn.textContent = 'Envoi…';
      const missionId = (document.getElementById('proposer-mission') as HTMLSelectElement).value;
      const chosen = missions.find((m: any) => m.id === missionId);
      const message = (document.getElementById('proposer-msg') as HTMLTextAreaElement).value.trim() || null;
      const { error } = await supabase.from('candidatures').insert({
        mission_id: missionId,
        profil_id: profilId,
        proposer_id: uid,
        proposer_role: 'etablissement',
        message,
        mission_libelle: chosen ? `${chosen.metier || 'Mission'}${chosen.ville ? ' — ' + chosen.ville : ''}` : null,
        profil_libelle: `${p.metier || 'Remplaçant'}${p.zones ? ' — ' + p.zones : ''}`,
      });
      if (error) {
        btn.disabled = false;
        btn.textContent = 'Envoyer la proposition';
        if (error.code === '23505') {
          window.alert('Vous avez déjà proposé cette mission à ce profil.');
        } else {
          window.alert('Erreur : ' + error.message);
        }
        return;
      }
      actionBox.innerHTML = `
        <div class="card action-card">
          <h2>Proposition envoyée ✅</h2>
          <p class="action-note ok">Le remplaçant a été notifié. Suivez le statut dans <a href="/mon-espace">Mon espace</a>.</p>
        </div>`;
    });
  }

  initProfil();
  document.addEventListener('astro:page-load', initProfil);
</script>
