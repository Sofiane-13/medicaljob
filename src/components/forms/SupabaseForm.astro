---
import { SITE } from '@data/site';

export type Props = {
  /** Table Supabase cible (ex. "besoins", "remplacants") */
  table: string;
  /** id unique du formulaire */
  formId: string;
  /** Texte du bouton d'envoi */
  submitLabel?: string;
  /** Message de succès affiché après envoi */
  successText?: string;
};

const {
  table,
  formId,
  submitLabel = 'Envoyer',
  successText = 'Merci, votre demande a bien été enregistrée. Nous revenons vers vous rapidement.',
} = Astro.props;

const supabaseUrl = SITE.supabase.url;
const supabaseKey = SITE.supabase.anonKey;
const notConfigured = supabaseUrl.includes('XXXX') || supabaseKey.includes('XXXX');
---

<form id={formId} class="fs-form" data-not-configured={notConfigured ? 'true' : 'false'}>
  <!-- Honeypot anti-spam -->
  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="fs-honeypot" aria-hidden="true" />

  <slot />

  {
    notConfigured && (
      <p class="fs-warning" role="status">
        ⚠️ Stockage non configuré : renseignez votre projet Supabase dans
        <code>src/data/site.ts</code> et exécutez <code>supabase-schema.sql</code>.
      </p>
    )
  }

  <button type="submit" class="btn-primary btn-lg fs-submit">{submitLabel}</button>

  <p class="fs-success" hidden role="status">✅ {successText}</p>
  <p class="fs-error" hidden role="alert">
    Une erreur est survenue. Réessayez ou écrivez-nous directement par email.
  </p>
</form>

<style>
  .fs-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .fs-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .fs-submit {
    margin-top: 0.5rem;
    align-self: flex-start;
  }
  .fs-warning {
    font-size: var(--text-sm);
    color: #92400e;
    background: #fef3c7;
    border: 1px solid #fde68a;
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
  }
  .fs-warning code {
    font-family: var(--font-mono);
    font-size: 0.8em;
  }
  .fs-success {
    font-size: var(--text-base);
    color: #065f46;
    background: var(--color-teal-soft);
    border: 1px solid #99e5d8;
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
  }
  .fs-error {
    font-size: var(--text-sm);
    color: #991b1b;
    background: #fee2e2;
    border: 1px solid #fecaca;
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
  }
  @media (max-width: 480px) {
    .fs-submit {
      align-self: stretch;
      width: 100%;
    }
  }
</style>

<script is:inline define:vars={{ formId, table, supabaseUrl, supabaseKey }}>
  function initSupabaseForm() {
    const form = document.getElementById(formId);
    if (!form || form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    const success = form.querySelector('.fs-success');
    const errorEl = form.querySelector('.fs-error');
    const submit = form.querySelector('.fs-submit');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot : si rempli, on simule le succès sans rien envoyer.
      if (form.querySelector('[name="_gotcha"]').value) {
        form.reset();
        success.hidden = false;
        return;
      }

      if (form.dataset.notConfigured === 'true') {
        window.alert(
          'Stockage non configuré. Crée un projet Supabase, colle l’URL + la clé anon dans src/data/site.ts, puis exécute supabase-schema.sql.'
        );
        return;
      }

      // Construit la ligne : on ignore les champs techniques (_*) et le consentement.
      const payload = {};
      new FormData(form).forEach((value, key) => {
        if (key.startsWith('_') || key === 'rgpd') return;
        const v = typeof value === 'string' ? value.trim() : value;
        payload[key] = v === '' ? null : v;
      });

      success.hidden = true;
      errorEl.hidden = true;
      submit.disabled = true;
      const originalLabel = submit.textContent;
      submit.textContent = 'Envoi…';

      try {
        const res = await fetch(`${supabaseUrl}/rest/v1/${table}`, {
          method: 'POST',
          headers: {
            apikey: supabaseKey,
            Authorization: `Bearer ${supabaseKey}`,
            'Content-Type': 'application/json',
            Prefer: 'return=minimal',
          },
          body: JSON.stringify(payload),
        });
        if (res.ok) {
          form.reset();
          success.hidden = false;
          success.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          errorEl.hidden = false;
        }
      } catch (err) {
        errorEl.hidden = false;
      } finally {
        submit.disabled = false;
        submit.textContent = originalLabel;
      }
    });
  }

  initSupabaseForm();
  document.addEventListener('astro:page-load', initSupabaseForm);
</script>
