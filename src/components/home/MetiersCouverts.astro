---
import { METIERS } from '@data/metiers';
---

<section id="metiers" class="section">
  <div class="container-content">
    <div class="section-head" data-reveal>
      <span class="eyebrow">Métiers couverts</span>
      <h2 class="h-section">Tous les remplacements en santé, au même endroit</h2>
      <p class="lede section-lede">
        De l’hôpital à l’officine, MedicalJob couvre les principaux métiers du soin
        et de la pharmacie. Chaque métier a sa page dédiée.
      </p>
    </div>

    <div class="metiers-grid grid-3">
      {
        METIERS.map((m) => (
          <a href={`/metiers/${m.slug}`} class="metier-card card card-hover" data-reveal>
            <span class="metier-icone" aria-hidden="true">{m.icone}</span>
            <h3 class="metier-nom">Remplacement {m.nom.toLowerCase()}</h3>
            <p class="metier-cadre text-subtle">
              {m.cadre === 'officine'
                ? 'Officine · PUI'
                : m.cadre === 'hopital'
                  ? 'Hôpital · clinique · EHPAD'
                  : 'Hôpital · officine'}
            </p>
            <span class="metier-link">Voir les remplacements →</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-head {
    max-width: 40rem;
    margin-bottom: 3rem;
  }
  .section-lede {
    margin-top: 1rem;
  }
  .metier-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1.75rem;
  }
  .metier-icone {
    font-size: 2rem;
    width: 3.5rem;
    height: 3.5rem;
    display: grid;
    place-items: center;
    background: var(--color-bg-tint);
    border-radius: var(--radius-md);
    margin-bottom: 0.75rem;
  }
  .metier-nom {
    font-size: 1.1875rem;
  }
  .metier-link {
    margin-top: 1rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
  }
</style>
