---
import { SITE } from '@data/site';

export type Props = {
  /** Table Supabase cible (ex. "besoins", "remplacants") */
  table: string;
  /** id unique du formulaire */
  formId: string;
  /** Texte du bouton d'envoi */
  submitLabel?: string;
  /** Titre de l'écran de confirmation */
  successTitle?: string;
  /** Message de confirmation affiché après envoi */
  successText?: string;
  /** Lien d'action principal sur l'écran de confirmation */
  successCtaHref?: string;
  successCtaLabel?: string;
};

const {
  table,
  formId,
  submitLabel = 'Envoyer',
  successTitle = 'C’est envoyé !',
  successText = 'Merci, votre demande a bien été enregistrée. Nous revenons vers vous rapidement.',
  successCtaHref,
  successCtaLabel,
} = Astro.props;

const supabaseUrl = SITE.supabase.url;
const supabaseKey = SITE.supabase.anonKey;
const notConfigured = supabaseUrl.includes('XXXX') || supabaseKey.includes('XXXX');
const successId = `${formId}-success`;
---

<div class="fs-wrap">
  <form id={formId} class="fs-form" data-table={table} data-success={successId}>
    <!-- Honeypot anti-spam -->
    <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="fs-honeypot" aria-hidden="true" />

    <slot />

    {
      notConfigured && (
        <p class="fs-warning" role="status">
          ⚠️ Stockage non configuré : renseignez votre projet Supabase dans
          <code>src/data/site.ts</code> et exécutez le schéma SQL.
        </p>
      )
    }

    <button type="submit" class="btn-primary btn-lg fs-submit">{submitLabel}</button>

    <p class="fs-error" hidden role="alert">
      Une erreur est survenue. Réessayez ou écrivez-nous directement par email.
    </p>
  </form>

  <div class="fs-success" id={successId} hidden role="status" aria-live="polite">
    <span class="fs-success-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12" />
      </svg>
    </span>
    <h2 class="fs-success-title">{successTitle}</h2>
    <p class="fs-success-text">{successText}</p>
    <div class="fs-success-actions">
      {successCtaHref && (
        <a href={successCtaHref} class="btn-primary">{successCtaLabel ?? 'Continuer'}</a>
      )}
      <a href="/" class={successCtaHref ? 'btn-secondary' : 'btn-primary'}>Retour à l’accueil</a>
    </div>
  </div>
</div>

<style>
  .fs-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .fs-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .fs-submit {
    margin-top: 0.5rem;
    align-self: flex-start;
  }
  .fs-warning {
    font-size: var(--text-sm);
    color: #92400e;
    background: #fef3c7;
    border: 1px solid #fde68a;
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
  }
  .fs-warning code {
    font-family: var(--font-mono);
    font-size: 0.8em;
  }
  .fs-error {
    font-size: var(--text-sm);
    color: #991b1b;
    background: #fee2e2;
    border: 1px solid #fecaca;
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem;
  }

  /* Écran de confirmation */
  .fs-success {
    text-align: center;
    padding: 2rem 1rem;
  }
  .fs-success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: var(--color-teal-soft);
    color: var(--color-teal);
    margin-bottom: 1.25rem;
  }
  .fs-success-icon svg {
    width: 2rem;
    height: 2rem;
  }
  .fs-success-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.75rem;
  }
  .fs-success-text {
    color: var(--color-fg-muted);
    line-height: 1.6;
    max-width: 32rem;
    margin: 0 auto 1.75rem;
  }
  .fs-success-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
  @media (max-width: 480px) {
    .fs-submit {
      align-self: stretch;
      width: 100%;
    }
    .fs-success-actions {
      flex-direction: column;
    }
    .fs-success-actions a {
      width: 100%;
    }
  }
</style>

<script>
  import { supabase, supabaseConfigured } from '@lib/supabaseClient';

  function initForm(form: HTMLFormElement) {
    if (form.dataset.bound === 'true') return;
    form.dataset.bound = 'true';

    const table = form.dataset.table as string;
    const successId = form.dataset.success;
    const panel = successId ? document.getElementById(successId) : null;
    const errorEl = form.querySelector('.fs-error') as HTMLElement | null;
    const submit = form.querySelector('.fs-submit') as HTMLButtonElement;

    const showSuccess = () => {
      form.hidden = true;
      if (panel) {
        panel.hidden = false;
        panel.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot
      const gotcha = form.querySelector('[name="_gotcha"]') as HTMLInputElement | null;
      if (gotcha && gotcha.value) {
        showSuccess();
        return;
      }

      if (!supabaseConfigured) {
        window.alert('Stockage non configuré (Supabase).');
        return;
      }

      // Auth requise : on insère avec owner_id = utilisateur connecté.
      const {
        data: { session },
      } = await supabase.auth.getSession();
      if (!session) {
        const here = window.location.pathname + window.location.search;
        window.location.href = '/connexion?redirect=' + encodeURIComponent(here);
        return;
      }

      const payload: Record<string, unknown> = {};
      new FormData(form).forEach((value, key) => {
        if (key.startsWith('_') || key === 'rgpd') return;
        const v = typeof value === 'string' ? value.trim() : value;
        payload[key] = v === '' ? null : v;
      });
      payload.owner_id = session.user.id;

      if (errorEl) errorEl.hidden = true;
      submit.disabled = true;
      const originalLabel = submit.textContent;
      submit.textContent = 'Envoi…';

      const { error } = await supabase.from(table).insert(payload);

      submit.disabled = false;
      submit.textContent = originalLabel;

      if (error) {
        if (errorEl) errorEl.hidden = false;
        console.error('Insert error:', error);
      } else {
        showSuccess();
      }
    });
  }

  function initAll() {
    document.querySelectorAll<HTMLFormElement>('form.fs-form').forEach(initForm);
  }
  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>
